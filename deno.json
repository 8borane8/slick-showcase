{
	"lock": true,
	"nodeModulesDir": "auto",
	"tasks": {
		"dev": "deno run --watch=src,main.ts --allow-all --node-modules-dir=auto ./main.ts --no-cache",
		"start": "deno run --allow-all --node-modules-dir=auto ./main.ts",
		"install": "deno install --node-modules-dir=auto",
		"cache": "deno cache --node-modules-dir=auto ./main.ts"
	},

	"imports": {
		"@webtools/slick-server": "jsr:@webtools/slick-server@^0.6.11",
		"@webtools/slick-client": "jsr:@webtools/slick-client@^0.3.0",
		"@webtools/expressapi": "jsr:@webtools/expressapi@^0.8.1",

		"preact": "npm:preact@^10.29.2",
		"preact/hooks": "npm:preact@^10.29.2/hooks",
		"preact/jsx-runtime": "npm:preact@^10.29.2/jsx-runtime",
		"preact-root-fragment": "npm:preact-root-fragment@^0.3.1",
		"@preact/signals": "npm:@preact/signals@^2.9.1",

		"shiki": "npm:shiki@^4.2.0"
	},

	"compilerOptions": {
		"jsxImportSource": "preact",
		"jsx": "react-jsx"
	},

	"deploy": {
		"install": "deno task install",
		"build": "deno task cache",
		"runtime": {
			"type": "dynamic",
			"entrypoint": "main.ts",
			"memory_limit": 1024
		}
	},

	"fmt": {
		"indentWidth": 4,
		"lineWidth": 120,
		"useTabs": true
	}
}
